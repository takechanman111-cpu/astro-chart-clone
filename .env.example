# Copy this file to .env only in your private server environment.
# Do not commit .env.

NODE_ENV=development
HOST=127.0.0.1
PORT=4173
PUBLIC_SOURCE_URL=https://example.com/your-public-source-repository

# astronomy: current static-compatible engine
# auto: Swiss-compatible runtime if present, otherwise Astronomy Engine
# swiss: require Swiss-compatible runtime and fail if unavailable
ASTRO_TIMING_ENGINE=auto

# Optional Swiss runtime paths.
# SWETEST_PATH=/usr/local/bin/swetest
# SWISS_EPHEMERIS_PATH=/path/to/swiss-ephemeris/ephe

# Add private keys only to .env, never to source files.
# DATABASE_URL=
# RATE_LIMIT_MAX_PER_MINUTE=30
